<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.brainrot.italiano.ui.screens.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_quiz"
            app:destination="@id/quizFragment">
            <argument
                android:name="level"
                app:argType="integer" />
        </action>

        <action
            android:id="@+id/action_home_to_parent"
            app:destination="@id/parentFragment" />
    </fragment>

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.brainrot.italiano.ui.screens.quiz.QuizFragment"
        android:label="Quiz"
        tools:layout="@layout/fragment_quiz">

        <argument
            android:name="level"
            app:argType="integer"
            android:defaultValue="1" />
    </fragment>

    <fragment
        android:id="@+id/parentFragment"
        android:name="com.brainrot.italiano.ui.screens.parent.ParentFragment"
        android:label="Parent"
        tools:layout="@layout/fragment_parent" />
    <fragment
    android:id="@+id/spellingQuizFragment"
    android:name="com.brainrot.italiano.ui.screens.spelling.SpellingQuizFragment"
    android:label="Тест орфографии"
    tools:layout="@layout/fragment_spelling_quiz" />

</navigation>
